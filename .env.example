# Database
NUXT_DB_PATH=mydb.sqlite

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:5000

# GitHub OAuth (Get these from https://github.com/settings/developers)
# Create a new OAuth App with:
# - Homepage URL: http://localhost:5000
# - Authorization callback URL: http://localhost:5000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
